# 生产环境配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 必需配置 ====================

# Django安全密钥（必须修改！生成方式: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-production-secret-key-change-this-immediately

# 调试模式（生产环境必须为False）
DEBUG=False

# 允许访问的主机（多个用逗号分隔）
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ==================== 数据库配置 ====================

# 使用PostgreSQL时填写以下配置
DB_NAME=workbench
DB_USER=workbench_user
DB_PASSWORD=your_strong_database_password
DB_HOST=localhost
DB_PORT=5432

# 注意：如果使用SQLite，可以删除以上数据库配置

# ==================== AI配置 ====================

# OpenAI API密钥（用于笔记AI润色等功能）
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# ==================== 可选配置 ====================

# 外部API密钥（用于新闻推送等功能，格式: "user_id:api_key,user_id2:api_key2"）
EXTERNAL_API_KEYS=